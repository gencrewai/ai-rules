{
  "name": "ai-rules",
  "version": "1.0.0",
  "description": "Multi-AI tool rules synchronization — single source of truth for all AI coding assistants",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gencrewai/ai-rules"
  },
  "scripts": {
    "new": "node engine/scripts/new.mjs",
    "sync": "node engine/scripts/sync.mjs",
    "sync:apply": "node engine/scripts/sync.mjs --apply",
    "sync:dry": "node engine/scripts/sync.mjs --dry-run",
    "sync:prune": "node engine/scripts/sync.mjs --apply --prune",
    "sync:uninstall": "node engine/scripts/sync.mjs --uninstall",
    "validate": "node engine/scripts/validate.mjs",
    "onboard": "node engine/scripts/onboard.mjs",
    "scaffold": "node engine/cli/scaffold.mjs"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
